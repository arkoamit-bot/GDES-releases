# ==========================================================================
#  GDES / BGDDR — .gitignore
#  CRITICAL: never commit patient data (SQLite DBs, backups, media, exports).
# ==========================================================================

# Python
__pycache__/
*.py[cod]
.pytest_cache/
*.egg-info/

# --- Patient data & runtime state (NEVER commit) --------------------------
*.sqlite3
*.sqlite3.*
*.sqlite3-journal
*.sqlite3-wal
*.sqlite3-shm
db-*.sqlite3
*.bak
*.backup
*.dump
/Backups/
/Logs/
/Media/
/media/
/Exports/
/Imports/
/Temp/
.initialized
.shortcut_done
.kb_version
bgddr_paths.json

# --- Secrets --------------------------------------------------------------
.env
.secret_key
# Code-signing private keys must NEVER be committed (public .cer is fine).
*.pfx
*.p12
*.key
# Bundled Microsoft WebView2 bootstrapper (re-downloadable; not source).
desktop/installer/MicrosoftEdgeWebview2Setup.exe

# --- Node / front-end build ----------------------------------------------
node_modules/

# --- Django collected static (regenerated by collectstatic) ---------------
/staticfiles/

# --- Desktop build artifacts ---------------------------------------------
/dist/
/build/
/build_onefile/

# --- Misc / editor / OS ---------------------------------------------------
.Rhistory
.DS_Store
Thumbs.db
.claude/settings.local.json

# Scratch / per-machine customisations (never commit)
*-Dr-Wasim.*

# Keep the COMPILED stylesheet (static/css/app.css) and vendored JS committed so
# the app runs without a Node build; only re-run `npm run build:css` when the
# templates/CSS change.

# Build logs
build_pyinstaller.log
