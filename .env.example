# Django
DJANGO_SECRET_KEY=change-this-to-a-long-random-string
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,your-domain.com
DJANGO_DEBUG=0
DJANGO_SETTINGS_MODULE=bgddr.settings_prod

# PostgreSQL
POSTGRES_DB=bgddr
POSTGRES_USER=bgddr
POSTGRES_PASSWORD=change-this-to-a-strong-password
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Redis / Celery
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# Security (optional, recommended)
# HTTPS is terminated at nginx; set to True if behind HTTPS
CSRF_COOKIE_SECURE=True
SESSION_COOKIE_SECURE=True
